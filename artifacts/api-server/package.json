  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development DATABASE_URL=file:../../lib/db/sqlite.db pnpm run build && cross-env NODE_ENV=development DATABASE_URL=file:../../lib/db/sqlite.db pnpm run start",
